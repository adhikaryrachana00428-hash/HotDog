# Anakin Universal Scraper (https://anakin.io)
ANAKIN_API_KEY=your_anakin_api_key
ANAKIN_BASE_URL=https://api.anakin.io/v1

# Wire orchestration (https://anakin.io/docs/api-reference/wire)
WIRE_API_KEY=your_wire_api_key
WIRE_BASE_URL=https://api.anakin.io/v1
WIRE_ACTION_ID=your_wire_action_id

# Server
PORT=3001
CORS_ORIGIN=*

# Production/demo default should remain false.
# Set to true only for local offline testing without Wire/Anakin.
USE_HEURISTIC_FALLBACK=false
